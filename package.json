{
  "name": "mayan-relationship-mcp",
  "version": "0.1.1",
  "description": "MCP server for Mayan zodiac relationship compatibility analysis",
  "type": "module",
  "bin": {
    "mayan-relationship-mcp": "./dist/stdio.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "mcp": "bun run dist/stdio.js",
    "check": "bun run format:check && tsc --noEmit && bun run test",
    "format": "bunx prettier --write '**/*.{ts,css,html}'",
    "format:check": "bunx prettier --check '**/*.{ts,css,html}'",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.26.0",
    "agents": "^0.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.0.0"
  }
}
